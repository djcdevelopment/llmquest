# Copy this file to ".env" and fill in your token.
# Get the token from: Discord Developer Portal -> your app -> Bot -> Reset Token -> Copy.
# Treat it like a password / your authenticator. Never share it, never commit it.
DISCORD_TOKEN=

# Which local model the Kid uses (must be one you've `ollama pull`-ed). Default: llama3.2
OLLAMA_MODEL=llama3.2
